# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://127.0.0.1:27017/hrm-db

# JWT Configuration
JWT_ACCESS_SECRET=your_super_secret_jwt_access_token_key_32_chars_long
JWT_REFRESH_SECRET=your_super_secret_jwt_refresh_token_key_32_chars_long

# Cloudinary Config (Optional, falls back to local storage if empty)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email Config (Optional, logs to console if empty)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@hrm-app.com
